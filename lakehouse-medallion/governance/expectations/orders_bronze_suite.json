{
  "expectation_suite_name": "orders_bronze_suite",
  "meta": {
    "purpose": "Block promotion of malformed orders from Bronze to Silver"
  },
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {"min_value": 1, "max_value": 1000000000}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "order_id"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "customer_id"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "order_ts"}
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": {"column": "order_id"}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "channel",
        "value_set": ["web", "mobile", "store", "phone"]
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "status",
        "value_set": ["pending", "paid", "shipped", "delivered", "returned", "cancelled"]
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "total", "min_value": 0, "max_value": 1000000}
    },
    {
      "expectation_type": "expect_column_pair_values_a_to_be_greater_than_b",
      "kwargs": {"column_A": "total", "column_B": "subtotal", "or_equal": true}
    }
  ]
}
